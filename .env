AGENTS_ROOT=agents

MANAGER=claude
ARCHITECTS=claude:2,codex:1
EXECUTORS=claude:2,codex:1

# Deterministic gate. Empty = skip (always pass). Set per project, e.g.:
# GATE_CMD=ruff check . && pytest -q
GATE_CMD=

# 0 = unbounded (you supervise live). Otherwise hard safety cap per phase/task.
MAX_STEPS=0

CHECKPOINT_DB=.orchestrator/checkpoint.sqlite
